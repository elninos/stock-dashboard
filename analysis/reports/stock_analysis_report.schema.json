{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stock-dashboard.local/schemas/stock-analysis-report.schema.json",
  "title": "Stock Analysis Report",
  "type": "object",
  "required": [
    "date",
    "ticker",
    "name",
    "classification",
    "summary_one_line",
    "timeframes",
    "events",
    "active_thesis",
    "weakened_thesis",
    "warnings_top5",
    "current_judgment",
    "data_limitations"
  ],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "ticker": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "classification": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "summary_one_line": {
      "type": "string"
    },
    "timeframes": {
      "type": "object",
      "required": ["1m", "6m", "1y"],
      "properties": {
        "1m": { "$ref": "#/$defs/timeframe" },
        "6m": { "$ref": "#/$defs/timeframe" },
        "1y": { "$ref": "#/$defs/timeframe" }
      }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    },
    "active_thesis": {
      "type": "array",
      "items": { "type": "string" }
    },
    "weakened_thesis": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings_top5": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" },
      "maxItems": 5
    },
    "current_judgment": {
      "type": "object",
      "required": [
        "simple_pullback",
        "trend_continuation",
        "trend_break"
      ],
      "properties": {
        "simple_pullback": { "type": "string" },
        "trend_continuation": { "type": "string" },
        "trend_break": { "type": "string" }
      }
    },
    "data_limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "report_path": {
      "type": "string"
    },
    "json_path": {
      "type": "string"
    }
  },
  "$defs": {
    "timeframe": {
      "type": "object",
      "properties": {
        "price_change_pct": {
          "type": ["number", "string"]
        },
        "summary": {
          "type": "string"
        },
        "flow_summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "event": {
      "type": "object",
      "required": [
        "id",
        "period",
        "price_change",
        "driver",
        "current_validity"
      ],
      "properties": {
        "id": { "type": "string" },
        "period": { "type": "string" },
        "price_change": { "type": "string" },
        "driver": { "type": "string" },
        "current_validity": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "warning": {
      "type": "object",
      "required": [
        "rank",
        "title",
        "severity",
        "reason"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "title": { "type": "string" },
        "severity": { "type": "string" },
        "reason": { "type": "string" }
      }
    }
  }
}
